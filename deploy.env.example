# Web deploy
DEPLOY_WEB_BUILD_CMD="pnpm --dir apps/web build"
DEPLOY_WEB_DIST_DIR="apps/web/dist"
DEPLOY_WEB_S3_BUCKET="replace-with-web-bucket"
DEPLOY_WEB_S3_PREFIX=""
DEPLOY_WEB_CLOUDFRONT_DISTRIBUTION_ID=""
DEPLOY_CLOUDFRONT_INVALIDATION_PATHS="/*"

# API deploy
# Example:
# DEPLOY_API_DEPLOY_CMD="ssh ubuntu@api-host 'cd /srv/stdev && git pull && systemctl restart diary-api'"
DEPLOY_API_DEPLOY_CMD=""

# Terraform
DEPLOY_RUN_TERRAFORM=0
DEPLOY_TERRAFORM_DIR="infra/service"
DEPLOY_TERRAFORM_INIT=0
DEPLOY_TERRAFORM_INIT_ARGS=""
DEPLOY_TERRAFORM_APPLY_ARGS="-auto-approve"

# Health check
DEPLOY_HEALTHCHECK_URL=""

# Optional AWS overrides
DEPLOY_AWS_PROFILE=""
DEPLOY_AWS_REGION="ap-northeast-2"
